{% set metrics = configuration.get('metricsDisplayOrder') %}
<div>
    <label>{{ "Metric display order"|trans({}, 'admin') }}</label>
    <p class="mt-0.5 mb-2 text-xxs text-gray-500">{{ "Choose the order the metrics are shown in."|trans({}, 'admin') }}</p>
    <div class="flex flex-col gap-2">
        {% for position in 1..3 %}
            <select name="config[metricsDisplayOrder][]">
                {% for context in enum('App\\Domain\\Dashboard\\StatsContext').cases() %}
                    <option value="{{ context.value }}" {{ metrics[position - 1] is defined and metrics[position - 1] == context.value ? 'selected' }}>{{ context|trans }}</option>
                {% endfor %}
            </select>
        {% endfor %}
    </div>
</div>