{% set challenges = configuration.get('challenges') %}
{% set unitLabels = {
    'km': 'km', 'm': 'm', 'mi': 'mi', 'ft': 'ft',
    'hour': 'hours'|trans, 'minute': 'minutes'|trans({}, 'admin'),
} %}
<div data-repeater data-repeater-min="0">
    <div class="flex flex-col gap-3"
         data-repeater-list
         data-repeater-initial="{{ challenges|json_encode|e('html_attr') }}">
    </div>
    <button type="button" data-repeater-add class="mt-2 btn--secondary inline-flex items-center gap-1.5">
        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
        </svg>
        <span>{{ "Add challenge"|trans({}, 'admin') }}</span>
    </button>
    <template data-repeater-template>
        <div class="relative flex flex-col gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200" data-repeater-item>
            <button type="button" data-repeater-remove
                    class="unstyled cursor-pointer absolute top-2 right-2 grid place-items-center size-9 shrink-0 text-gray-400 transition-colors hover:text-red-600"
                    aria-label="{{ "Remove challenge"|trans({}, 'admin') }}">
                <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
                </svg>
            </button>
            <div class="grid gap-3 pr-11 md:grid-cols-2 lg:grid-cols-4">
                <div>
                    <label class="mt-0!">{{ "Label"|trans({}, 'admin') }}</label>
                    <input type="text" name="config[challenges][__index__][label]"
                           data-repeater-field="label" required placeholder="{{ "Challenge name"|trans({}, 'admin') }}">
                </div>
                <div>
                    <label class="mt-0!">{{ "Type"|trans({}, 'admin') }}</label>
                    <select name="config[challenges][__index__][type]" data-repeater-field="type">
                        {% for type in enum('App\\Domain\\Challenge\\Consistency\\ChallengeConsistencyType').cases() %}
                            <option value="{{ type.value }}">{{ type|trans }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="mt-0!">{{ "Goal"|trans }}</label>
                    <input type="number" step="any" min="0" name="config[challenges][__index__][goal]"
                           data-repeater-field="goal" required placeholder="0">
                </div>
                <div>
                    <label class="mt-0!">{{ "Unit"|trans({}, 'admin') }}</label>
                    <select name="config[challenges][__index__][unit]" data-repeater-field="unit">
                        {% for unit, unitLabel in unitLabels %}
                            <option value="{{ unit }}">{{ unitLabel }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div>
                <label class="mt-0!">{{ "Sport types to include"|trans({}, 'admin') }}</label>
                <div class="mt-1 max-h-40 overflow-y-auto flex flex-col gap-1.5 rounded-lg border border-gray-200 p-2">
                    {% for sportType in enum('App\\Domain\\Activity\\SportType\\SportType').cases() %}
                        <label class="flex items-center gap-2 mt-0! text-sm font-normal cursor-pointer">
                            <input type="checkbox" name="config[challenges][__index__][sportTypesToInclude][]"
                                   value="{{ sportType.value }}" data-repeater-field="sportTypesToInclude">
                            <span>{{ sportType|trans }}</span>
                        </label>
                    {% endfor %}
                </div>
                <p class="mt-1 text-xxs text-gray-500">{{ "Leave empty to include all sport types."|trans({}, 'admin') }}</p>
            </div>
        </div>
    </template>
</div>
