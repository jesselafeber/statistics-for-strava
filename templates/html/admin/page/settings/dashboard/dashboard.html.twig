{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% set dashboardUrl = relativeUrl(path('admin_settings_dashboard')) %}
    {% autoescape false %}
        <form data-dashboard-layout-form data-save-command="{{ saveLayoutCommand }}" class="p-4 sm:p-6 bg-white border border-gray-200 rounded-lg shadow-xs max-w-6xl">
            <div class="flex flex-wrap items-start justify-between gap-3 mb-1">
                <div>
                    <h3 class="text-lg font-semibold">{{ "Dashboard layout"|trans({}, 'admin') }}</h3>
                    <p class="mt-1 text-sm text-gray-500">
                        {{ "Reorder widgets and set each widget's width."|trans({}, 'admin') }}
                    </p>
                </div>
                <button id="addWidgetButton" data-dropdown="addWidgetDropdown" data-dropdown-placement="bottom-end" type="button" class="btn--add">
                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
                    </svg>
                    <span>{{ "Add widget"|trans({}, 'admin') }}</span>
                </button>
            </div>
            <input type="hidden" name="layout" data-layout-field>
            <div class="grid grid-cols-6 gap-3 mt-4" data-widget-grid>
                {% for widget in widgets %}
                    <div class="flex flex-col rounded-lg border border-gray-200 bg-white shadow-xs" data-widget-id="{{ widget.getId() }}" data-width="{{ widget.getWidth() }}">
                        <div class="flex items-center gap-2 px-3 py-2 border-b border-gray-100">
                            <span class="shrink-0 text-gray-400 cursor-grab active:cursor-grabbing" data-drag-handle title="{{ "Drag to reorder"|trans({}, 'admin') }}">
                                <svg class="size-4.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6h.01M9 12h.01M9 18h.01M15 6h.01M15 12h.01M15 18h.01"/>
                                </svg>
                            </span>
                            <span class="min-w-0 truncate text-sm font-medium text-gray-800">{{ widget.getLabel() }}</span>
                            {% if widget.stillNeedsConfiguration() %}
                                <span class="shrink-0 text-amber-500" title="{{ "This widget still needs to be configured."|trans({}, 'admin') }}">
                                    <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 13V8m0 8h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                                    </svg>
                                </span>
                            {% endif %}
                            <div class="ml-auto flex items-center gap-1.5 shrink-0">
                                {% if widget.isConfigurable() %}
                                    <a href="{{ relativeUrl(path('admin_configure_dashboard_widget', {'dashboardWidgetId': widget.getId()})) }}" class="text-gray-400 hover:text-primary p-1 rounded-md hover:bg-gray-100" title="{{ "Configure"|trans({}, 'admin') }}">
                                        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13v-2a1 1 0 0 0-1-1h-.757l-.707-1.707.535-.536a1 1 0 0 0 0-1.414l-1.414-1.414a1 1 0 0 0-1.414 0l-.536.535L14 4.757V4a1 1 0 0 0-1-1h-2a1 1 0 0 0-1 1v.757l-1.707.707-.536-.535a1 1 0 0 0-1.414 0L4.929 6.343a1 1 0 0 0 0 1.414l.536.536L4.757 10H4a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h.757l.707 1.707-.535.536a1 1 0 0 0 0 1.414l1.414 1.414a1 1 0 0 0 1.414 0l.536-.535 1.707.707V20a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-.757l1.707-.708.536.536a1 1 0 0 0 1.414 0l1.414-1.414a1 1 0 0 0 0-1.414l-.535-.536.707-1.707H20a1 1 0 0 0 1-1Z"/>
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                                        </svg>
                                    </a>
                                {% endif %}
                                <a href="{{ relativeUrl(path('admin_delete_dashboard_widget', {'dashboardWidgetId': widget.getId()})) }}" class="text-gray-300 hover:text-red-600 p-1 rounded-md hover:bg-red-50" title="{{ "Remove widget"|trans({}, 'admin') }}">
                                    <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                        <div class="flex-1 px-3 py-3">
                            <div class="flex h-full min-h-16 flex-col justify-center gap-2 rounded-md border border-dashed border-gray-200 bg-gray-50/60 px-3 py-3">
                                <div class="h-2 w-1/3 rounded bg-gray-200"></div>
                                <div class="h-2 w-2/3 rounded bg-gray-200"></div>
                                <div class="h-2 w-1/2 rounded bg-gray-200"></div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between gap-2 px-3 py-2 border-t border-gray-100">
                            <div class="inline-flex rounded-md border border-gray-200 bg-gray-50 p-0.5 text-xxs font-medium" data-width-seg>
                                {% for width in widths %}
                                    <button type="button" data-w="{{ width }}" aria-pressed="{{ width == widget.getWidth() ? 'true' : 'false' }}" class="unstyled">{{ width }}%</button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="sticky bottom-0 z-10 -mx-4 sm:-mx-6 -mb-4 sm:-mb-6 mt-6 flex items-center justify-between gap-2 rounded-b-lg border-t border-gray-200 bg-white px-4 sm:px-6 py-2">
                <a href="{{ relativeUrl(path('admin_reset_dashboard_layout')) }}" type="button" class="btn--secondary">{{ "Reset to default"|trans({}, 'admin') }}</a>
                <span data-layout-status role="status" aria-live="polite"></span>
            </div>
        </form>
        <div id="addWidgetDropdown" class="hidden z-20 w-72 max-h-96 overflow-y-auto rounded-lg border border-gray-200 bg-white p-1 shadow-xl">
            <p class="px-2 py-1.5 text-xxs uppercase font-semibold tracking-wide text-gray-400">{{ "Add a widget"|trans({}, 'admin') }}</p>
            {% set configuredWidgetCountPerType = widgets.getConfiguredWidgetCountPerType() %}
            {% for name, widget in widgets.getAvailableWidgets() %}
                <form data-dispatch-command="{{ addWidgetCommand }}" data-redirect="{{ dashboardUrl }}">
                    <input type="hidden" name="widget" value="{{ name }}">
                    <button type="submit" class="unstyled cursor-pointer flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-sm text-gray-700 hover:bg-primary-soft hover:text-primary">
                        <svg class="size-4 shrink-0 text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
                        </svg>
                        <span class="flex-1 truncate">{{ widget.getLabel() }}</span>
                        {% if configuredWidgetCountPerType[name] is defined %}
                            <span class="shrink-0 inline-flex items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-gray-100 text-xxs font-semibold text-gray-500" title="{{ "Number of widgets of this type you already have configured."|trans({}, 'admin') }}">{{ configuredWidgetCountPerType[name] }}</span>
                        {% endif %}
                    </button>
                </form>
            {% endfor %}
        </div>
    {% endautoescape %}
{% endblock main %}
