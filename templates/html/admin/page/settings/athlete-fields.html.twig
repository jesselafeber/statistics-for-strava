{% import 'html/admin/page/settings/macro/history-editor.html.twig' as editor %}
{% set genderOptions = {'M': 'Male'|trans({}, 'admin'), 'F': 'Female'|trans({}, 'admin'), 'X': 'Other'|trans} %}
{% set maxHeartRateFormulaOptions = ['arena', 'astrand', 'fox', 'gellish', 'nes', 'tanaka'] %}
{% set maxHeartRateFormula = athlete.maxHeartRateFormula %}
{% set restingHeartRateFormula = athlete.restingHeartRateFormula %}

{% set maxHeartRateType = maxHeartRateFormula is iterable ? 'dateRangeBased' : maxHeartRateFormula %}
{% set restingHeartRateType = restingHeartRateFormula is iterable ? 'dateRangeBased' : (restingHeartRateFormula == 'heuristicAgeBased' ? 'heuristicAgeBased' : 'fixed') %}
{% set restingHeartRateFixedValue = 'fixed' == restingHeartRateType ? restingHeartRateFormula : '' %}

{% set maxHeartRateRanges = [] %}
{% for on, bpm in 'dateRangeBased' == maxHeartRateType ? maxHeartRateFormula : [] %}
    {% set maxHeartRateRanges = maxHeartRateRanges|merge([{'on': on, 'bpm': bpm}]) %}
{% endfor %}
{% set restingHeartRateRanges = [] %}
{% for on, bpm in 'dateRangeBased' == restingHeartRateType ? restingHeartRateFormula : [] %}
    {% set restingHeartRateRanges = restingHeartRateRanges|merge([{'on': on, 'bpm': bpm}]) %}
{% endfor %}
<div class="flex flex-col gap-4">
    <div class="grid gap-4 sm:grid-cols-2">
        <div>
            <label for="firstName">{{ "First name"|trans({}, 'admin') }}</label>
            <input type="text" id="firstName" name="{{ fieldPrefix }}[firstName]" value="{{ athlete.firstName ?? '' }}">
        </div>
        <div>
            <label for="lastName">{{ "Last name"|trans({}, 'admin') }}</label>
            <input type="text" id="lastName" name="{{ fieldPrefix }}[lastName]" value="{{ athlete.lastName ?? '' }}">
        </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
        <div>
            <label for="birthday">{{ "Birthday"|trans({}, 'admin') }}</label>
            <input type="date" id="birthday" name="{{ fieldPrefix }}[birthday]" value="{{ athlete.birthday ?? '' }}" required>
            <p class="description">
                {{ "Your birthday. Needed to calculate heart rate zones."|trans({}, 'admin') }}
            </p>
        </div>
        <div>
            <label for="gender">{{ "Gender"|trans({}, 'admin') }}</label>
            <select id="gender" name="{{ fieldPrefix }}[gender]">
                {% for value, genderLabel in genderOptions %}
                    <option value="{{ value }}" {{ (athlete.gender ?? '') == value ? 'selected' : '' }}>{{ genderLabel }}</option>
                {% endfor %}
            </select>
            <p class="description">
                {{ "Your gender. Used to determine activity training load."|trans({}, 'admin') }}
            </p>
        </div>
    </div>
    <div class="group/max-hr">
        <label for="maxHeartRateFormula">{{ "Max heart rate formula"|trans({}, 'admin') }}</label>
        <select id="maxHeartRateFormula" name="{{ fieldPrefix }}[maxHeartRateFormula]">
            {% for formula in maxHeartRateFormulaOptions %}
                <option value="{{ formula }}" {{ maxHeartRateType == formula ? 'selected' : '' }}>{{ formula }}</option>
            {% endfor %}
            <option value="dateRangeBased" {{ 'dateRangeBased' == maxHeartRateType ? 'selected' : '' }}>{{ "Date range based"|trans({}, 'admin') }}</option>
        </select>
        <p class="description">
            {{ "The formula used to calculate your max heart rate. The default is Fox (220 − age)."|trans({}, 'admin') }}
        </p>
        <div class="hidden mt-2 group-has-[option[value=dateRangeBased]:checked]/max-hr:block">
            {{ editor.historyEditor(
                fieldPrefix ~ '[maxHeartRateFormulaRanges]',
                maxHeartRateRanges,
                null,
                "Your measured max heart rate, applied from the given date onwards."|trans({}, 'admin'),
                "Max heart rate (bpm)"|trans({}, 'admin'),
                "Add max heart rate"|trans({}, 'admin'),
                'bpm',
                '1',
                false
            ) }}
        </div>
    </div>
    <div class="group/resting-hr">
        <label for="restingHeartRateFormula">{{ "Resting heart rate formula"|trans({}, 'admin') }}</label>
        <select id="restingHeartRateFormula" name="{{ fieldPrefix }}[restingHeartRateFormula]">
            <option value="heuristicAgeBased" {{ 'heuristicAgeBased' == restingHeartRateType ? 'selected' : '' }}>{{ "Age-based estimate"|trans({}, 'admin') }}</option>
            <option value="fixed" {{ 'fixed' == restingHeartRateType ? 'selected' : '' }}>{{ "Fixed value"|trans({}, 'admin') }}</option>
            <option value="dateRangeBased" {{ 'dateRangeBased' == restingHeartRateType ? 'selected' : '' }}>{{ "Date range based"|trans({}, 'admin') }}</option>
        </select>
        <p class="description">
            {{ "The formula used to calculate your resting heart rate. The default is an age-based estimate."|trans({}, 'admin') }}
        </p>
        <div class="hidden mt-2 group-has-[option[value=fixed]:checked]/resting-hr:block">
            <label for="restingHeartRateFormulaFixedValue" class="mt-0! text-xs text-gray-500">{{ "Resting heart rate (bpm)"|trans({}, 'admin') }}</label>
            <input type="number" min="20" max="250" step="1" id="restingHeartRateFormulaFixedValue" name="{{ fieldPrefix }}[restingHeartRateFormulaFixedValue]" value="{{ restingHeartRateFixedValue }}">
        </div>
        <div class="hidden mt-2 group-has-[option[value=dateRangeBased]:checked]/resting-hr:block">
            {{ editor.historyEditor(
                fieldPrefix ~ '[restingHeartRateFormulaRanges]',
                restingHeartRateRanges,
                null,
                "Your measured resting heart rate, applied from the given date onwards."|trans({}, 'admin'),
                "Resting heart rate (bpm)"|trans({}, 'admin'),
                "Add resting heart rate"|trans({}, 'admin'),
                'bpm',
                '1',
                false
            ) }}
        </div>
    </div>
</div>
