{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        {% embed 'html/admin/component/gated-panel.html.twig' with { 'locked': not importMode.isFiles() } %}
            {% block lockTitle %}{% autoescape false %}{{ "File imports are only available in file import mode"|trans({}, 'admin') }}{% endautoescape %}{% endblock %}
            {% block content %}{% autoescape false %}
                <h3 class="text-lg font-semibold mb-4">
                    {{ "File imports"|trans({}, 'admin') }}
                </h3>
                <div class="relative overflow-x-auto">
                    <table class="data-table">
                        <thead>
                        <tr>
                            <th scope="col" class="text-left">
                                {{ "Processed on"|trans({}, 'admin') }}
                            </th>
                            <th scope="col" class="text-left">
                                {{ "Filename"|trans({}, 'admin') }}
                            </th>
                            <th scope="col" class="text-left">
                                {{ "Source"|trans({}, 'admin') }}
                            </th>
                            <th scope="col" class="text-left">
                                {{ "Activity"|trans }}
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for fileImport in overview %}
                            <tr class="group/row {{ fileImport.isFailed() ? 'bg-red-50/60' : '' }}">
                                <td class="whitespace-nowrap text-left font-medium text-gray-800">
                                    <div class="flex items-center justify-start gap-2">
                                        {% if fileImport.isFailed() %}
                                            <span class="grid place-items-center size-7 shrink-0 rounded-lg bg-red-100 text-red-500"
                                                  title="{{ fileImport.getErrorMessage() }}" aria-label="{{ "Failed"|trans({}, 'admin') }}">
                                                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                                            </span>
                                        {% elseif fileImport.wasSkipped() %}
                                            <span class="grid place-items-center size-7 shrink-0 rounded-lg bg-amber-100 text-amber-500"
                                                  title="{{ fileImport.getErrorMessage() }}" aria-label="{{ "Skipped"|trans({}, 'admin') }}">
                                                  <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 13V8m0 8h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                                                    </svg>
                                            </span>
                                        {% else %}
                                            <span class="grid place-items-center size-7 shrink-0 rounded-lg bg-green-100 text-green-600"
                                                  aria-label="{{ "Success"|trans({}, 'admin') }}">
                                                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M20 6L9 17l-5-5"/></svg>
                                            </span>
                                        {% endif %}
                                        <span>
                                            {{ fileImport.getImportedOn()|formatDate() }}
                                            <span class="text-xs">{{ fileImport.getImportedOn()|formatTime(true) }}</span>
                                        </span>
                                    </div>
                                </td>
                                <td class="whitespace-nowrap text-left">
                                    {{ fileImport.getOriginalFilename() }}
                                </td>
                                <td class="whitespace-nowrap text-left">
                                    {{ fileImport.getSource().label() }}
                                </td>
                                <td class="whitespace-nowrap text-left">
                                    {% set activityId = fileImport.getActivityId() %}
                                    {% if activityId %}
                                        <a class="font-medium text-blue-600 hover:underline" href="{{ relativeUrl('/activities#/activity/' ~ activityId ~ '.html') }}">
                                            {{ fileImport.getActivityName() }}
                                        </a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        {% if overview.isEmpty() %}
                            <tr>
                                <td colspan="4">
                                    <div class="flex flex-col items-center justify-center gap-3 py-12 px-4 text-center">
                                        <span class="grid place-items-center size-12 rounded-full bg-gray-100 text-gray-400" aria-hidden="true">
                                            <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                                        </span>
                                        <div class="flex flex-col gap-1">
                                            <span class="text-sm font-medium text-gray-800">{{ "No files imported yet."|trans({}, 'admin') }}</span>
                                            <span class="text-xs text-gray-500">{{ "Imported files will appear here once you upload them."|trans({}, 'admin') }}</span>
                                        </div>
                                        <a href="{{ relativeUrl(path('admin_file_upload')) }}" type="button" class="btn--primary mt-1">
                                            {{ "Upload files"|trans({}, 'admin') }}
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
                {% include 'html/admin/component/pagination.html.twig' with {
                    'total': overview.getTotal(),
                    'pagination': overview.getPagination(),
                } only %}
            {% endautoescape %}{% endblock %}
        {% endembed %}
    </div>
    {% endautoescape %}
{% endblock main %}
